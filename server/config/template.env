# server/config/template.env
#
# Reference for every CONFIG_* variable. Copy to `server/.env` (gitignored)
# and fill in values for local development. Production injects via the
# orchestrator (k8s Secret / Compose secrets / Swarm secrets / etc.).
#
# Loaded by `dotenvy::dotenv()` at the top of bin/server.rs (best-effort,
# dev-only). The default search path is `.env` relative to the current working
# directory — so `cargo run` from `server/` picks up `server/.env`.
#
# See server/docs/config.md for the full reference and per-var description.

# ── Required: secrets and connection URLs ─────────────────────────────────

# Telegram bot token from @BotFather. Format: <digits>:<≥30 url-safe chars>.
# Never logged — wrapped in `BotToken(***redacted***)` newtype.
CONFIG_BOT_TOKEN=

# PostgreSQL connection URL.
CONFIG_DATABASE_URL=postgresql://vixen:vixen_dev_password@localhost:5432/vixen

# Redis connection URL (mandatory from M0 — caches + pub/sub).
CONFIG_REDIS_URL=redis://localhost:6379

# Comma-separated Telegram chat IDs the bot watches.
# Negative IDs (-100…) for groups/supergroups, positive for private chats.
# Must list at least one ID.
CONFIG_CHATS=

# ── Operational ──────────────────────────────────────────────────────────

# HTTP bind address.
# CONFIG_ADDRESS=0.0.0.0:8000

# Deployment environment: dev | staging | prod.
# Affects log defaults, OpenAPI UI exposure, prod-only secret enforcement.
# CONFIG_ENVIRONMENT=dev

# Console log level: trace | debug | info | warn | error. Overridden by RUST_LOG.
# CONFIG_LOG_LEVEL=info

# Directory for the rolling JSON file logger. Daily rotation, 7-day retention.
# CONFIG_LOG_DIR=./logs

# Mount the Scalar OpenAPI UI at /scalar. Default: true in dev, false elsewhere.
# CONFIG_OPENAPI_UI=

# CORS allowed origins. No wildcards. Comma-separated.
# CONFIG_CORS_ORIGINS=http://localhost:3000

# ── Telegram bot mode ────────────────────────────────────────────────────

# polling (default; M0–M5) or webhook (M6+).
# CONFIG_TELEGRAM_MODE=polling

# Public HTTPS URL Telegram POSTs updates to. Required when mode=webhook.
# CONFIG_TELEGRAM_WEBHOOK_URL=

# Validated against the X-Telegram-Bot-Api-Secret-Token header. Required when mode=webhook.
# CONFIG_TELEGRAM_WEBHOOK_SECRET=

# ── Auth ────────────────────────────────────────────────────────────────

# Constant-time-compared bearer for /admin/*. Required in prod.
# CONFIG_ADMIN_SECRET=

# HS256 signing secret for dashboard JWTs (≥32 bytes). Required in prod.
# CONFIG_JWT_SECRET=

# Dashboard JWT TTL in seconds.
# CONFIG_JWT_TTL_SECS=3600

# Reject Telegram WebApp initData whose auth_date is older than this.
# CONFIG_INIT_DATA_MAX_AGE_SECS=86400

# ── Database pool ───────────────────────────────────────────────────────

# CONFIG_DB_MAX_CONNECTIONS=50
# CONFIG_DB_MIN_CONNECTIONS=5
# CONFIG_DB_ACQUIRE_TIMEOUT_MS=10000
# CONFIG_DB_IDLE_TIMEOUT_MS=600000
# CONFIG_DB_STATEMENT_TIMEOUT_MS=30000
