##############
## COMMON
##############

# Logs
logs/
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Config
/config/*
!/config/template.yaml
!/config/template.yml
!/config/template.env

# Coverage directories
coverage/
*.lcov
report/

# Build directories
dist/
target/
out/
build/
debug/

# Playwright
.playwright-mcp/

##############
## FRONTEND (website/)
##############

# Dependency directories
node_modules/
jspm_packages/

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# nyc test coverage
.nyc_output

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# temp and cache directory
.temp
.cache

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# macOS
.DS_Store

# JetBrains
.idea/
*.iml

# VS Code
.vscode/chrome-debug/
.vscode/firefox-debug/

##############
## BACKEND (server/)
##############

# Rustfmt backup files
**/*.rs.bk

# MSVC Windows builds of rustc generate these
*.pdb

# Generated by cargo mutants
**/mutants.out*/

# Database files (dev artefacts only — production runs against PostgreSQL)
/data/*

##############
## CLAUDE
##############

# Per-developer local overrides (allow-only, no team-wide effect)
.claude/*.local.json
.claude/*.lock

##############
## SECRETS / DEV ARTIFACTS
##############

# Screenshots & ad-hoc images at repo root
screenshots/
/*.png

# Captcha preview snapshots produced locally
captcha_samples/

# Bot token / credentials sandbox
.secrets/
