# docker/.env.example — copy to docker/.env (gitignored) and adjust as needed.
#
# Two layers of values live here:
#   1. Overrides for docker-compose.yml (POSTGRES_*, REDIS_PORT).
#   2. Connection URLs for `cargo run` (DATABASE_URL, REDIS_URL).
#
# The server reads its own envs from `server/.env.local` (see server/config/template.env);
# the values below match the docker-compose defaults so `cargo run` from server/ works
# out of the box against a freshly-started compose stack.

# ────────────────────────────────────────────────────────────────────────────
# docker-compose overrides
# ────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=vixen
POSTGRES_PASSWORD=vixen_dev_password
POSTGRES_DB=vixen
POSTGRES_PORT=5432

REDIS_PORT=6379

# ────────────────────────────────────────────────────────────────────────────
# Server connection URLs (cargo run)
# ────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://vixen:vixen_dev_password@localhost:5432/vixen
REDIS_URL=redis://localhost:6379
