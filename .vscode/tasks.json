{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "docker:build",
            "detail": "Build server using Docker.",
            "icon": {
                "color": "terminal.ansiBlue",
                "id": "azure"
            },
            "type": "shell",
            "command": "docker",
            "options": {
                "cwd": "${workspaceFolder}/docker",
                "env": {}
            },
            "osx": {
                "args": [
                    "buildx",
                    "build",
                    "--platform=linux/arm64",
                    "--build-arg=UBUNTU_VERSION=24.04",
                    "--build-arg=BUILD_DATE=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")",
                    "--build-arg=VCS_REF=$(git rev-parse HEAD)",
                    "--build-arg=VCS_URL=$(git config --get remote.origin.url)",
                    "--tag=plugfox/vixen-rs:local",
                    "--file=tools/docker/Dockerfile",
                    "."
                ]
            },
            "windows": {
                "args": [
                    "buildx",
                    "build",
                    "--platform=linux/amd64",
                    "--build-arg=UBUNTU_VERSION=24.04",
                    "--build-arg=BUILD_DATE=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")",
                    "--build-arg=VCS_REF=$(git rev-parse HEAD)",
                    "--build-arg=VCS_URL=$(git config --get remote.origin.url)",
                    "--tag=plugfox/vixen-rs:local",
                    "--file=tools/docker/Dockerfile",
                    "."
                ]
            },
            "linux": {
                "args": [
                    "buildx",
                    "build",
                    "--platform=linux/amd64,linux/arm64",
                    "--build-arg=UBUNTU_VERSION=24.04",
                    "--build-arg=BUILD_DATE=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")",
                    "--build-arg=VCS_REF=$(git rev-parse HEAD)",
                    "--build-arg=VCS_URL=$(git config --get remote.origin.url)",
                    "--tag=plugfox/vixen-rs:local",
                    "--file=tools/docker/Dockerfile",
                    "."
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "docker:compose:up",
            "detail": "Start Docker services",
            "icon": {
                "color": "terminal.ansiGreen",
                "id": "cloud"
            },
            "type": "shell",
            "command": [
                "docker compose --env-file=.env --file='docker-compose.yml' --profile=server --project-name='vixen' up -d"
            ],
            "args": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/tools/docker"
            },
            "isBackground": false,
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true,
                "group": "docker"
            }
        },
        {
            "label": "docker:compose:down",
            "detail": "Stop Docker services",
            "icon": {
                "color": "terminal.ansiRed",
                "id": "cloud"
            },
            "type": "shell",
            "command": [
                "docker compose --project-name=vixen --profile=server down"
            ],
            "args": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/tools/docker"
            },
            "isBackground": false,
            "presentation": {
                "reveal": "never",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false,
                "group": "docker"
            }
        },
        {
            "label": "cargo:lint",
            "detail": "Lint Rust using cargo clippy.",
            "type": "shell",
            "command": "cargo clippy",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "cargo:format",
            "detail": "Format Rust using cargo fmt.",
            "type": "shell",
            "command": "cargo fmt",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "cargo:test",
            "detail": "Run tests for Rust using cargo test.",
            "type": "shell",
            "command": "cargo test",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "cargo:build",
            "detail": "Build Rust using cargo build.",
            "type": "shell",
            "command": "cargo build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "test:all",
            "detail": "Run all tests with output",
            "icon": {
                "color": "terminal.ansiGreen",
                "id": "beaker"
            },
            "type": "shell",
            "command": "cargo",
            "args": [
                "test",
                "--",
                "--nocapture"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_LOG": "debug",
                    "RUST_BACKTRACE": "1"
                }
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            "label": "test:db:concurrency",
            "detail": "Run database concurrency tests",
            "icon": {
                "color": "terminal.ansiRed",
                "id": "database"
            },
            "type": "shell",
            "command": "cargo",
            "args": [
                "test",
                "db::tests",
                "--release",
                "--",
                "--nocapture"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_LOG": "debug",
                    "RUST_BACKTRACE": "1"
                }
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            "label": "test:stress",
            "detail": "Run high contention stress test",
            "icon": {
                "color": "terminal.ansiYellow",
                "id": "zap"
            },
            "type": "shell",
            "command": "cargo",
            "args": [
                "test",
                "test_high_contention_stress",
                "--release",
                "--",
                "--nocapture"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_LOG": "debug",
                    "RUST_BACKTRACE": "1"
                }
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            "label": "cargo:clippy",
            "detail": "Run clippy linter",
            "icon": {
                "color": "terminal.ansiCyan",
                "id": "tools"
            },
            "type": "shell",
            "command": "cargo",
            "args": [
                "clippy",
                "--all-targets",
                "--all-features"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "run:server:release",
            "detail": "Run server in release mode",
            "icon": {
                "color": "terminal.ansiGreen",
                "id": "rocket"
            },
            "type": "shell",
            "command": "cargo",
            "args": [
                "run",
                "--release",
                "--bin",
                "server"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_LOG": "info"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "isBackground": true,
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "dev:check",
            "detail": "Quick development check: format, clippy, and test",
            "icon": {
                "color": "terminal.ansiMagenta",
                "id": "checklist"
            },
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "cargo fmt; if ($LASTEXITCODE -eq 0) { cargo clippy --all-targets --all-features; if ($LASTEXITCODE -eq 0) { cargo test -- --nocapture } }"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_LOG": "debug",
                    "RUST_BACKTRACE": "1"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            "label": "run:server:debug",
            "detail": "Run server in debug mode with hot reload",
            "icon": {
                "color": "terminal.ansiBlue",
                "id": "debug-start"
            },
            "type": "shell",
            "command": "cargo",
            "args": [
                "run",
                "--bin",
                "server"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_LOG": "debug",
                    "RUST_BACKTRACE": "1"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "isBackground": true,
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        }
    ]
}